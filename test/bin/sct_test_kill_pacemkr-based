#!/bin/bash
#
# sct_test_kill_pacemkr-based - kill pacemaker-based
#
# NEW SYNTAX:
#           sct_test_kill_pacemakerd --by-role ROLE
#           sct_test_kill_pacemakerd --node HOST
# OLD-STYLE: 
#           sct_test_kill_pacemakerd ROLE
# ROLE:
#           prim[:master|worker] | secn[:master|worker] | third | fourth
#
# (c) 2025-2026 SUSE LLC
# Author: F.Herschel, L.Pinne.
# GNU General Public License v2. No warranty.
# http://www.gnu.org/licenses/gpl.html
#
set -u
killNode=""
srRole=""
while [[ "$#" -gt 0 ]]; do
    case "$1" in
        --by-role ) # by-role ROLE
                    shift
                    srRole="$1"  # should be prim[:master|worker] or secn[:master|worker] | third | fourth
                    ;;
        --node )    # node HOST
                    shift
                    killNode="$1"
                    ;;
        prim | prim:* | secn | secn:* | third | fourth )
                    srRole="$1"
                    echo "by-role $srRole"
                    ;;
        * )         #
                    echo "unknown parameter $1"
    esac
    shift
done
rc=1 # mark fail, by default
dirname=$(dirname "$0")
source /usr/lib/SAPHanaSR-tester/sct_test_lib ||  source "$dirname"/../lib/sct_test_lib && echo "loading alternative test library from source directory"
source .test_properties
if [[ -n "$killNode" ]]; then
    echo "killNode=$killNode (set by command line)"
else
    case "$srRole" in
        prim | prim:master ) killNode=$(sctl_get_curr_prim "$node01");;
        secn | secn:master ) killNode=$(sctl_get_curr_secn "$node01");;
        prim:worker        ) killNode=$(sctl_get_curr_prim_worker "$node01");;
        secn:worker        ) killNode=$(sctl_get_curr_secn_worker "$node01");;
        third              ) killNode="$tHost";; # TODO: Check, if we need a sctl_get_curr_third function
        fourth             ) killNode="$fHost";; # TODO: Check, if we need a sctl_get_curr_fourth_function
        * ) echo "Neither prim, secn, third nor fourth in cmd line ($srRole)"
            exit 2;;
    esac
    echo "killNode=$killNode (selected by role $srRole)"
fi

if [[ -n "$killNode" ]]; then
    echo "==== Kill pacemaker-based on $killNode ===="
    # TODO signal 9 ?
    sctl_kill_process "$killNode" "hacluster" "pacemaker-based" "11" "flags::"; rc="$?"
else
    echo "no killNode defined/found"
    rc=2
fi
exit "$rc"
#
