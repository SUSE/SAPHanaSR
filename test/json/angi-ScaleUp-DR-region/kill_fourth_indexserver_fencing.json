{
    "test": "kill_fourth_indexserver_fencing",
    "name": "Kill fourth indexserver with on-fail fencing",
    "purpose": [
        "angi",
        "ScaleUp",
        "DRregion",
        "fourth",
        "kill",
        "hana",
        "hadr",
        "susChkSrv",
        "fencing"
    ],
    "start": "prereq10",
    "steps": [
        {
            "step": "prereq10",
            "name": "test prerequisites",
            "next": "step20",
            "loop": 1,
            "wait": 1,
            "post": "kill_fourth_indexserver",
            "mstRsc": "mstRscReady",
            "tSite": "tSiteUp",
            "fSite": "fSiteUp",
            "tHost": "tHostUp",
            "fHost": "fHostUp"
        },
        {
            "step": "step20",
            "name": "failure detected + fourth fenced",
            "next": "step30",
            "loop": 120,
            "wait": 2,
            "tSite": "tSiteUp",
            "tHost": "tHostUp",
            "fSite": [
                "lpt == 10",
                "srr == S",
                "srHook == SFAIL"
            ],
            "fHost": [
                "clone_state is None",
                "roles is None",
                "score is None"
            ]
        },
        {
            "step": "step30",
            "name": "begin recover",
            "next": "final50",
            "loop": 240,
            "wait": 2,
            "tSite": "tSiteUp",
            "tHost": "tHostUp",
            "fSite": [
                "lpt == 10",
                "lss ~ (1|2)",
                "srr == S",
                "srHook ~ (SFAIL|SWAIT)",
                "srPoll == DR"
            ],
            "fHost": [
                "clone_state ~ (UNDEFINED|DEMOTED)",
                "roles == master1::worker:",
                "score ~ (-1234|-5678)"
            ]
        },
        {
            "step": "final50",
            "name": "end recover",
            "next": "END",
            "loop": 240,
            "wait": 2,
            "post": "cleanup",
            "tSite": "tSiteUp",
            "fSite": "fSiteUp",
            "tHost": "tHostUp",
            "fHost": "fHostUp"
        }
    ]
