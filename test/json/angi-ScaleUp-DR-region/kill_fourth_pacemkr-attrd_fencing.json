{
    "test": "kill_fourth_pacemkr-attrd_fencing",
    "name": "kill pacemaker-attrd on fourth node",
    "purpose": [
        "angi",
        "ScaleUp",
        "Flupsi",
        "fourth",
        "kill",
        "cluster",
        "todo",
        "fencing"
    ],
    "start": "prereq10",
    "steps": [
        {
            "step": "prereq10",
            "name": "test prerequisites",
            "next": "step20",
            "loop": 1,
            "wait": 1,
            "post": "shell sct_test_kill_pacemkr-attrd fourth",
            "mstRsc": "mstRscReady",
            "tSite": "tSiteUp",
            "fSite": "fSiteUp",
            "tHost": "tHostUp",
            "fHost": "fHostUp"
        },
        {
            "step": "step20",
            "name": "failure detected",
            "next": "step30",
            "loop": 120,
            "wait": 2,
            "tSite": "tSiteUp",
            "tHost": "tHostUp",
            "fSite": [
                "srHook ~ (PRIM|SOK)"
            ],
            "fHost": [
                "lpt ~ (10|30)",
                "clone_state ~ (PROMOTED|DEMOTED)",
                "roles == master1:master:worker:master",
                "lss == 4",
                "srr ~ (S|P)",
                "score ~ (-1234|-5678)"
            ]
        },
        {
            "step": "step30",
            "name": "begin recover",
            "next": "final40",
            "loop": 180,
            "wait": 2,
            "fSite": "fSiteUp",
            "fHost": [
                "lpt ~ (10|30)",
                "clone_state ~ (DEMOTED|PROMOTED)",
                "roles == master1:master:worker:master",
                "lss == 4",
                "srr == P",
                "score ~ (-1234|-5678)"
            ]
        },
        {
            "step": "final40",
            "name": "end recover",
            "next": "END",
            "loop": 150,
            "wait": 2,
            "post": "cleanup",
            "tSite": "tSiteUp",
            "fSite": "fSiteUp",
            "tHost": "tHostUp",
            "fHost": "fHostUp"
        }
    ]
}
