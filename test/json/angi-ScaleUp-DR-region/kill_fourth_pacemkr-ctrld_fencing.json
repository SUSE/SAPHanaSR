{
    "test": "kill_fourth_pacemkr-ctrld_fencing",
    "name": "kill pacemaker-controld on fourth node",
    "purpose": [
        "angi",
        "ScaleUp",
        "Flupsi",
        "fourth",
        "kill",
        "cluster",
        "fencing"
    ],
    "start": "prereq10",
    "steps": [
        {
            "step": "prereq10",
            "name": "test prerequisites",
            "next": "step20",
            "loop": 1,
            "wait": 1,
            "post": "shell sct_test_kill_pacemkr-ctrld fourth",
            "mstRsc": "mstRscReady",
            "tSite": "tSiteUp",
            "fSite": "fSiteUp",
            "tHost": "tHostUp",
            "fHost": "fHostUp"
        },
        {
            "step": "step20",
            "name": "failure detected - node down",
            "next": "step30",
            "loop": 120,
            "wait": 2,
            "tSite": "tSiteUp",
            "tHost": "tHostUp",
            "fSite": [
                "lpt == 10",
                "srr == S",
                "srHook == SFAIL",
                "srPoll == DR"
            ],
            "fHost": [
                "clone_state is None",
                "roles is None",
                "score is None"
            ]
        },
        {
            "step": "step30",
            "name": "begin recover",
            "next": "final40",
            "loop": 180,
            "wait": 2,
            "tSite": "tSiteUp",
            "tHost": "tHostUp",
            "fSite": [
                "lpt == 10",
                "lss ~ (1|2)",
                "srr == S",
                "srHook ~ (SFAIL|SWAIT)",
                "srPoll == DR"
            ],
            "fHost": [
                "clone_state ~ (UNDEFINED|DEMOTED)",
                "roles == master1::worker:",
                "score ~ (-INFINITY|0|-1)"
            ]
        },
        {
            "step": "final40",
            "name": "end recover",
            "next": "END",
            "loop": 240,
            "wait": 2,
            "post": "cleanup",
            "tSite": "tSiteUp",
            "fSite": "fSiteUp",
            "tHost": "tHostUp",
            "fHost": "fHostUp"
        }
    ]
}
