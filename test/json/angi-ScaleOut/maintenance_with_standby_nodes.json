{
    "test": "maintenance_with_standby_nodes",
    "name": "standby+online secondary then standby+online primary",
    "purpose": [
        "angi",
        "ScaleOut",
        "maintenance",
        "hana",
        "primary",
        "secondary",
        "cluster"
    ],
    "start": "prereq10",
    "steps": [
        {
            "step": "prereq10",
            "name": "test prerequisites standby_secn_node",
            "next": "step20",
            "loop": 1,
            "wait": 1,
            "post": "ssn",
            "pSite": "pSiteUp",
            "pHost": "pHostUp",
            "pWorker": "pWorkerUp",
            "sSite": "sSiteUp",
            "sHost": "sHostUp",
            "sWorker": "sWorkerUp"
        },
        {
            "step": "step20",
            "name": "secondary site: node is standby",
            "next": "step30",
            "loop": 120,
            "wait": 2,
            "post": "osn",
            "pSite": "pSiteUp",
            "pHost": "pHostUp",
            "pWorker": "pWorkerUp",
            "sSite": "sSiteDown",
            "sHost": "sHostStandby",
            "sWorker": [
                "clone_state == DEMOTED",
                "roles == slave::worker:"
            ]
        },
        {
            "step": "step30",
            "name": "secondary site: node back online",
            "next": "step40",
            "loop": 120,
            "wait": 2,
            "pSite": "pSiteUp",
            "pHost": "pHostUp",
            "pWorker": "pWorkerUp",
            "sSite": [
                "lpt == 10",
                "lss == 1",
                "srr == S",
                "srHook == SWAIT",
                "srPoll == SFAIL"
            ],
            "sHost": [
                "clone_state == DEMOTED",
                "roles == master1::worker:",
                "score ~ (-INFINITY|0)"
            ]
        },
        {
            "step": "step40",
            "name": "end recover",
            "next": "step110",
            "loop": 120,
            "wait": 2,
            "pSite": "pSiteUp",
            "pHost": "pHostUp",
            "pWorker": "pWorkerUp",
            "sSite": "sSiteUp",
            "sHost": "sHostUp",
            "sWorker": "sWorkerUp"
        },
        {
            "step": "step110",
            "name": "test prerequisites standby_prim_node",
            "next": "step120",
            "loop": 1,
            "wait": 1,
            "post": "spn",
            "pSite": "pSiteUp",
            "pHost": "pHostUp",
            "pWorker": "pWorkerUp",
            "sSite": "sSiteUp",
            "sHost": "sHostUp",
            "sWorker": "sWorkerUp"
        },
        {
            "step": "step120",
            "name": "primary site: node is standby",
            "next": "step130",
            "loop": 120,
            "wait": 2,
            "pSite": [
                "lpt == 10",
                "lss == 1",
                "srr == P",
                "srHook == PRIM"
            ],
            "sSite": [
                "lpt >~ 1000000000:30",
                "lss == 4",
                "srr == S",
                "srHook ~ (PRIM|SOK)",
                "srPoll == SOK"
            ],
            "pHost": "pHostStandby",
            "sHost": [
                "clone_state == PROMOTED",
                "roles == master1:master:worker:master",
                "score ~ (100|145)"
            ]
        },
        {
            "step": "step130",
            "name": "takeover on secondary",
            "next": "final140",
            "loop": 120,
            "post": "opn",
            "wait": 2,
            "pSite": [
                "lss == 1",
                "srr == P",
                "lpt == 10",
                "srHook == SWAIT",
                "srPoll == SFAIL"
            ],
            "sSite": "pSiteUp",
            "pHost": [
                "clone_state == UNDEFINED",
                "roles == master1::worker:",
                "score == 150",
                "standby == on"
            ],
            "sHost": "pHostUp"
        },
        {
            "step": "final140",
            "name": "end recover",
            "next": "END",
            "loop": 120,
            "wait": 2,
            "post": "cleanup",
            "pSite": "sSiteUp",
            "sSite": "pSiteUp",
            "pHost": "sHostUp",
            "sHost": "pHostUp",
            "pWorker": "sWorkerUp",
            "sWorker": "pWorkerUp"
        }
    ]
}
